{
  "name": "repuestero-app",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && gradlew.bat assembleRelease",
    "android:bundle:release": "npm run android:sync && cd android && gradlew.bat bundleRelease",
    "android:assets": "capacitor-assets generate --android",
    "ios:sync": "npm run build && cap sync ios",
    "ios:open": "cap open ios",
    "ios:assets": "capacitor-assets generate --ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "supabase:deploy-notify": "npx supabase functions deploy notify-registro",
    "supabase:deploy-mecanico": "npx supabase functions deploy mecanico-virtual-obd",
    "supabase:deploy-vision": "node scripts/deploy-vision.mjs",
    "check-encoding": "node scripts/check-src-encoding.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "8.3.3",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.98.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jimp": "^1.6.0",
    "supabase": "^2.98.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
