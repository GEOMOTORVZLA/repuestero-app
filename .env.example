# Supabase - reemplaza con tus valores del dashboard de Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Google Maps / Places API
VITE_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key
#
# URL pública del sitio (sin barra final). Obligatoria coherente en builds de APK: los enlaces
# "Compartir por WhatsApp" deben apuntar aquí, no a capacitor://localhost.
# VITE_PUBLIC_SITE_URL=https://geomotorvzla.com
#
# Dominio de producción (ej. https://geomotorvzla.com): en Supabase → Authentication → URL
# configuration añade Site URL y Redirect URLs; en Google Cloud → Credenciales de la API key
# de Maps añade el referente https://geomotorvzla.com/* (y /motos si aplica).

# Opcional: enlace al borrador en Google Docs (se muestra en la página legal si está definido)
# VITE_POLITICA_DIVULGACION_DOC_URL=https://docs.google.com/document/d/.../edit
